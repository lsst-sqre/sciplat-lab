#!/usr/bin/env bash
set -x

set -eo pipefail  # -u and conda don't play well: ADDR2LINE: unbound variable

# Install-compat will have ensured this exists.  It might be a symlink.
cd /etc/nublado/versions-installed

# We add the "-sciplat" because we also have base packages here, and it is
# possible we will overwrite some of them in sciplat-lab installation.

# First system packages
dpkg -l | tee "system-dpkgs-sciplat"
uv pip list | tee "system-python-sciplat"
npm list --global --long --json | tee "node-modules-sciplat"

# Now JupyterLab python

source /etc/nublado/venv/bin/activate
cd ${vi_dir}
uv pip list | tee "jupyterlab-python-sciplat"
# If lab extensions do not load, we will get a nonzero return code.  Suppress.
((jupyter labextension list 2>&1) | tee "lab-extensions-sciplat") || /bin/true
deactivate

# Finally, the stack
SHELL=bash
export SHELL
source /opt/lsst/software/stack/loadLSST.bash
cd ${vi_dir}
conda env export | tee "conda-stack.yaml"

